rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Règle pour la collection 'users'
    // Seul l'utilisateur propriétaire peut lire et écrire ses propres données
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Par défaut, tout le reste est bloqué pour plus de sécurité
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
